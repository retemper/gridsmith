{
  "name": "@gridsmith/core",
  "version": "1.0.4",
  "type": "module",
  "description": "Headless core for Gridsmith data grid — state, editing engine, virtualization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/retemper/gridsmith",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
